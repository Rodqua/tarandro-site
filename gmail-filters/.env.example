# ─── gmail-filters/.env ───────────────────────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs.
# Les clés OAuth sont exactement les mêmes que celles de tarandro.org.
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Base de données — même DATABASE_URL que le projet Next.js (Supabase pooler)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true

# Google OAuth — mêmes credentials que tarandro.org
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://tarandro.org/api/mail/connect/callback

# Microsoft OAuth — optionnel (pour enrichir les filtres depuis Outlook)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Zoho OAuth — optionnel (pour enrichir les filtres depuis Zoho)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REGION=eu
