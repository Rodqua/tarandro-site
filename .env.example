# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-in-production-use-openssl-rand-base64-32

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tarandro?schema=public"

# Admin Credentials (Development only - use env variables in production)
ADMIN_USERNAME=admin
# Password: admin123
# To generate a hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=$2a$10$YourHashedPasswordHere

# Mode Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_TOKEN=your-secret-bypass-token-change-in-production

# Email Configuration (for contact form)
# Option 1 : Resend (Recommandé)
RESEND_API_KEY=your-resend-api-key
EMAIL_TO=contact@tarandro.org

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Option 2 : SMTP (Gmail, SendGrid, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@tarandro.org

# ===== MODULE MAIL =====
# Google OAuth — Gmail API
# Créer sur https://console.cloud.google.com > APIs & Services > Identifiants
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://tarandro.org/api/mail/connect/callback

# Microsoft OAuth — Outlook/Hotmail (à configurer plus tard)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=https://tarandro.org/api/mail/connect/microsoft/callback

# Zoho Mail — IMAP (à configurer plus tard)
# ZOHO_EMAIL=
# ZOHO_APP_PASSWORD=
