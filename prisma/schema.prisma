generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EmailAccount {
  id           String        @id @default(cuid())
  provider     String
  email        String
  displayName  String?
  accessToken  String        @db.Text
  refreshToken String?       @db.Text
  expiresAt    DateTime?
  signature    String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  threads      EmailThread[]

  @@unique([provider, email])
}

model EmailThread {
  id          String       @id @default(cuid())
  threadId    String
  messageId   String?
  accountId   String
  account     EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject     String       @db.Text
  snippet     String       @db.Text
  sender      String
  date        DateTime
  isUnread    Boolean      @default(true)
  isArchived  Boolean      @default(false)
  attachmentCount Int       @default(0)
  category    String       @default("important")
  labels      String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([accountId, threadId])
  @@index([accountId, isUnread])
  @@index([date])
  @@index([category])
}

model FilterRule {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  field       String   @default("all")
  pattern     String   @db.Text
  category    String
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationPreference {
  id          String   @id @default(cuid())
  email       String   @unique
  enabled     Boolean  @default(true)
  hour        Int      @default(8)
  timezone    String   @default("Europe/Paris")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CategoryConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  emoji     String   @default("📁")
  color     String   @default("text-gray-700")
  bg        String   @default("bg-gray-50 border-gray-200")
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── EVJF Lise ────────────────────────────────────────────────────────────────

enum EvjfRole {
  ORGANIZER
  PARTICIPANT
}

enum EvjfCategory {
  ACTIVITY
  FOOD
  TRANSPORT
  ACCOMMODATION
  DECO
  OTHER
}

enum EvjfIdeaStatus {
  PENDING
  VALIDATED
  REJECTED
  RETAINED
}

enum EvjfVoteType {
  POSITIVE
  VETO
}

model EvjfUser {
  id        String        @id @default(cuid())
  name      String        @unique
  role      EvjfRole      @default(PARTICIPANT)
  avatarUrl String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  ideas     EvjfIdea[]
  votes     EvjfVote[]
  comments  EvjfComment[]
  messages  EvjfMessage[]
  reactions   EvjfReaction[]
  budgetItems  EvjfBudgetItem[]
  programPaid  EvjfProgramBlock[] @relation("ProgramBlockPaidBy")

  @@map("evjf_users")
}

model EvjfIdea {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  category        EvjfCategory
  estimatedBudget Float?
  referenceUrl    String?
  imageUrl       String?
  status          EvjfIdeaStatus @default(PENDING)
  authorId        String
  author          EvjfUser       @relation(fields: [authorId], references: [id])
  votes           EvjfVote[]
  comments        EvjfComment[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("evjf_ideas")
}

model EvjfVote {
  id        String       @id @default(cuid())
  ideaId    String
  idea      EvjfIdea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      EvjfUser     @relation(fields: [userId], references: [id])
  type      EvjfVoteType
  createdAt DateTime     @default(now())

  @@unique([ideaId, userId])
  @@map("evjf_votes")
}

model EvjfComment {
  id        String   @id @default(cuid())
  ideaId    String
  idea      EvjfIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      EvjfUser @relation(fields: [userId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@map("evjf_comments")
}

model EvjfMessage {
  id        String         @id @default(cuid())
  content   String         @db.Text
  authorId  String
  author    EvjfUser       @relation(fields: [authorId], references: [id])
  isPinned  Boolean        @default(false)
  reactions EvjfReaction[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("evjf_messages")
}

model EvjfReaction {
  id        String      @id @default(cuid())
  messageId String
  message   EvjfMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      EvjfUser    @relation(fields: [userId], references: [id])
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@map("evjf_reactions")
}

model EvjfProgramBlock {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  startTime   String       // "HH:MM" format
  endTime     String       // "HH:MM" format
  category    EvjfCategory
  location    String?
  locationUrl String?
  imageUrl    String?
  paidById    String?
  paidBy      EvjfUser?    @relation("ProgramBlockPaidBy", fields: [paidById], references: [id])
  isPaid      Boolean      @default(false)
  notes       String?      @db.Text
  budget      Float?
  order       Int          @default(0)
  day         Int          @default(1) // jour 1, 2, etc. si EVJF sur plusieurs jours
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("evjf_program_blocks")
}

model EvjfBudgetItem {
  id         String       @id @default(cuid())
  label      String
  amount     Float
  category   EvjfCategory
  paidById   String?
  paidBy     EvjfUser?    @relation(fields: [paidById], references: [id])
  splitCount Int          @default(7)
  isPaid     Boolean      @default(false)
  note       String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("evjf_budget_items")
}
