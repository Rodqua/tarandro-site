generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EmailAccount {
  id           String        @id @default(cuid())
  provider     String
  email        String
  displayName  String?
  accessToken  String        @db.Text
  refreshToken String?       @db.Text
  expiresAt    DateTime?
  signature    String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  threads      EmailThread[]

  @@unique([provider, email])
}

model EmailThread {
  id          String       @id @default(cuid())
  threadId    String
  messageId   String?
  accountId   String
  account     EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject     String       @db.Text
  snippet     String       @db.Text
  sender      String
  date        DateTime
  isUnread    Boolean      @default(true)
  isArchived  Boolean      @default(false)
  attachmentCount Int       @default(0)
  category    String       @default("important")
  labels      String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([accountId, threadId])
  @@index([accountId, isUnread])
  @@index([date])
  @@index([category])
}

model FilterRule {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  field       String   @default("all")
  pattern     String   @db.Text
  category    String
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationPreference {
  id          String   @id @default(cuid())
  email       String   @unique
  enabled     Boolean  @default(true)
  hour        Int      @default(8)
  timezone    String   @default("Europe/Paris")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CategoryConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  emoji     String   @default("📁")
  color     String   @default("text-gray-700")
  bg        String   @default("bg-gray-50 border-gray-200")
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())
}
